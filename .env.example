# Postgres connection string (Supabase or any Postgres).
# Supabase: Project Settings → Database → Connection string → "URI" (use the pooler/6543 for serverless).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Stripe (Phase 2)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Auth (Phase 3) — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public site URL (used for SEO canonical/sitemap/OG). No trailing slash.
NEXT_PUBLIC_BASE_URL="https://www.bigrigcomponents.com"

# Owner-only admin access. Comma-separated emails allowed into /admin.
# Leave empty to fall back to the users.role = 'admin' check.
ADMIN_EMAILS="owner@bigrigcomponents.com"

# Transactional email (Resend). Without this, emails are silently skipped.
RESEND_API_KEY=""
# Must be a verified Resend domain (or use onboarding@resend.dev for testing).
RESEND_FROM_EMAIL="Big Rig Components <orders@bigrigcomponents.com>"

# Image storage in production (Vercel Blob). Without it, uploads go to disk
# (fine for local/self-hosted, NOT for Vercel serverless).
BLOB_READ_WRITE_TOKEN=""
